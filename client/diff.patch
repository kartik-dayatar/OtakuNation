+    // User: Add Review
+    addReview: (productId, review) => {
+        set((state) => {
+            const updatedProducts = state.products.map((p) => {
+                if (p.id === parseInt(productId)) {
+                    const newReviewsList = p.reviewsList ? [review, ...p.reviewsList] : [review];
+                    const newReviewCount = (p.reviews || 0) + 1;
+                    const newRating = ((p.rating || 0) * (p.reviews || 0) + review.rating) / newReviewCount;
+
+                    return {
+                        ...p,
+                        reviews: newReviewCount,
+                        rating: parseFloat(newRating.toFixed(1)),
+                        reviewsList: newReviewsList
+                    };
+                }
+                return p;
+            });
+            return { products: updatedProducts };
+        });
     }
